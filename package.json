  "description": "CozoScript grammar for tree-sitter",
  "main": "bindings/node",
  "keywords": ["parser", "tree-sitter", "cozo", "cozoscript", "datalog"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.cozo",
